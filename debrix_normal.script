%===========================================================
% GMAT MISSION SCRIPT
% DEBRI-X Swarm Dock-and-Dump Debris Removal Concept
% Research Version - Fixed and Enhanced for GMAT R2025a
% Pure ASCII - Single-line statements only
% Fixes applied:
%   1. Removed Create CoordinateSystem EarthFixed (built-in)
%   2. Removed all DrawLabel fields (not in R2025a)
%   3. Fixed DrawObject to use [] array syntax
%   4. Fixed COLLECTOR.FuelMass -> COLLECTOR.TotalMass
%   5. Added 5 more OrbitViews, 3 more GroundTracks, 6 more ReportFiles
%   6. Added XYPlot visualizations for SMA, ECC, INC, altitude trends
%   7. Added extra variables: dv1, dv2, dv3, missionElapsed, orbitPeriod
%   8. Extended Phase 7 to 30 days with more report checkpoints
%===========================================================

%-----------------------------------------------------------
% FORCE MODEL
%-----------------------------------------------------------

Create ForceModel EarthForces;
EarthForces.CentralBody = Earth;
EarthForces.PrimaryBodies = {Earth};
EarthForces.GravityField.Earth.Degree = 8;
EarthForces.GravityField.Earth.Order = 8;
EarthForces.GravityField.Earth.Model = JGM2;
EarthForces.PointMasses = {Sun, Luna};
EarthForces.Drag = None;
EarthForces.SRP = On;
EarthForces.SRP.Flux = 1367;
EarthForces.SRP.SRPModel = Spherical;

%-----------------------------------------------------------
% PROPAGATOR
%-----------------------------------------------------------

Create Propagator OrbitProp;
OrbitProp.FM = EarthForces;
OrbitProp.Type = RungeKutta89;
OrbitProp.InitialStepSize = 60;
OrbitProp.Accuracy = 1e-12;
OrbitProp.MinStep = 0.001;
OrbitProp.MaxStep = 86400;

%-----------------------------------------------------------
% SWARM SPACECRAFT (10 units, 36-deg spacing)
