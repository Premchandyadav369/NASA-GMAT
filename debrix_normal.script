DebrisTrackLog.Filename = 'debris_track_log.txt';
DebrisTrackLog.Add = {DebrisA.UTCGregorian, DebrisA.SMA, DebrisA.ECC, DebrisA.INC, DebrisB.SMA, DebrisB.ECC, DebrisC.SMA, DebrisC.ECC, DebrisD.SMA, DebrisD.ECC, DebrisE.SMA, DebrisE.ECC, DebrisF.SMA, DebrisG.SMA, DebrisH.SMA, DebrisI.SMA, DebrisJ.SMA};
