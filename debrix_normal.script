Report MissionSummaryLog COLLECTOR.UTCGregorian phase debrisCount swarmSignal reentryFlag dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.Altitude COLLECTOR.ECC COLLECTOR.INC;

%-----------------------------------------------------------
% PHASE 6 - SECOND DETECTION CYCLE
%-----------------------------------------------------------

phase = 6;
debrisCount = 0;
swarmSignal = 0;

debrisCount = debrisCount + 6;
Report SwarmLog debrisCount swarmSignal phase reentryFlag COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.TotalMass;
Report MissionSummaryLog COLLECTOR.UTCGregorian phase debrisCount swarmSignal reentryFlag dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.Altitude COLLECTOR.ECC COLLECTOR.INC;

Propagate OrbitProp(DEBRIX1, DEBRIX2, DEBRIX3, DEBRIX4, DEBRIX5, DEBRIX6, DEBRIX7, DEBRIX8, DEBRIX9, DEBRIX10, DebrisA, DebrisB, DebrisC, DebrisD, DebrisE, DebrisF, DebrisG, DebrisH, DebrisI, DebrisJ) {DEBRIX1.ElapsedDays = 0.5};

