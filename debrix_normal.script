%-----------------------------------------------------------
% TANK
% FIX: Tank must be named and then Tanks list must reference it
%      COLLECTOR.FuelMass is invalid - use COLLECTOR.TotalMass
%-----------------------------------------------------------

Create ChemicalTank MainTank;
MainTank.AllowNegativeFuelMass = false;
MainTank.FuelMass = 80;
MainTank.Pressure = 1500;
MainTank.Temperature = 20;
MainTank.RefTemperature = 20;
MainTank.Volume = 0.1;
MainTank.FuelDensity = 1000;
MainTank.PressureModel = PressureRegulated;

COLLECTOR.Tanks = {MainTank};

%-----------------------------------------------------------
% MANEUVERS
%-----------------------------------------------------------

Create ImpulsiveBurn DeorbitBurn1;
DeorbitBurn1.CoordinateSystem = Local;
DeorbitBurn1.Origin = Earth;
DeorbitBurn1.Axes = VNB;
DeorbitBurn1.Element1 = -0.150;
DeorbitBurn1.Element2 = 0.0;
DeorbitBurn1.Element3 = 0.0;
DeorbitBurn1.DecrementMass = true;
DeorbitBurn1.Tank = {MainTank};
DeorbitBurn1.Isp = 220;
DeorbitBurn1.GravitationalAccel = 9.81;

Create ImpulsiveBurn DeorbitBurn2;
DeorbitBurn2.CoordinateSystem = Local;
DeorbitBurn2.Origin = Earth;
DeorbitBurn2.Axes = VNB;
DeorbitBurn2.Element1 = -0.150;
DeorbitBurn2.Element2 = 0.0;
DeorbitBurn2.Element3 = 0.0;
DeorbitBurn2.DecrementMass = true;
DeorbitBurn2.Tank = {MainTank};
DeorbitBurn2.Isp = 220;
DeorbitBurn2.GravitationalAccel = 9.81;

Create ImpulsiveBurn DeorbitBurn3;
DeorbitBurn3.CoordinateSystem = Local;
DeorbitBurn3.Origin = Earth;
DeorbitBurn3.Axes = VNB;
DeorbitBurn3.Element1 = -0.100;
DeorbitBurn3.Element2 = 0.0;
DeorbitBurn3.Element3 = 0.0;
DeorbitBurn3.DecrementMass = true;
DeorbitBurn3.Tank = {MainTank};
DeorbitBurn3.Isp = 220;
DeorbitBurn3.GravitationalAccel = 9.81;

