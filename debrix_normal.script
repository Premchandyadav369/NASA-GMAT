CartesianStateLog.WriteHeaders = true;
CartesianStateLog.ColumnWidth = 22;

Create ReportFile MissionSummaryLog;
MissionSummaryLog.Filename = 'mission_summary_log.txt';
MissionSummaryLog.Add = {COLLECTOR.UTCGregorian, phase, debrisCount, swarmSignal, reentryFlag, dv_total, COLLECTOR.TotalMass, COLLECTOR.SMA, COLLECTOR.Altitude, COLLECTOR.ECC, COLLECTOR.INC};
MissionSummaryLog.WriteHeaders = true;
MissionSummaryLog.ColumnWidth = 22;

%-----------------------------------------------------------
% XY PLOTS - Essential metrics only (2 plots to avoid crash)
%-----------------------------------------------------------

% Plot 1: Collector altitude over time - shows deorbit descent
Create XYPlot CollectorAltitudePlot;
CollectorAltitudePlot.SolverIterations = Current;
CollectorAltitudePlot.XVariable = COLLECTOR.ElapsedDays;
CollectorAltitudePlot.YVariables = {COLLECTOR.Altitude};
CollectorAltitudePlot.ShowPlot = true;

% Plot 2: Perigee and apogee radius - shows burn effects clearly
Create XYPlot CollectorRadiusPlot;
CollectorRadiusPlot.SolverIterations = Current;
CollectorRadiusPlot.XVariable = COLLECTOR.ElapsedDays;
CollectorRadiusPlot.YVariables = {COLLECTOR.RadPer, COLLECTOR.RadApo};
CollectorRadiusPlot.ShowPlot = true;

%-----------------------------------------------------------
% VISUALIZATION 1 - All spacecraft 3D inertial view
% FIX: Removed DrawLabel (not valid in R2025a)
% FIX: DrawObject must use [] array syntax
% NOTE: EarthFixed is built-in - never Create it
%-----------------------------------------------------------

Create OrbitView EarthView;
EarthView.Add = {DEBRIX1, DEBRIX2, DEBRIX3, DEBRIX4, DEBRIX5, DEBRIX6, DEBRIX7, DEBRIX8, DEBRIX9, DEBRIX10, COLLECTOR, DebrisA, DebrisB, DebrisC, DebrisD, DebrisE, DebrisF, DebrisG, DebrisH, DebrisI, DebrisJ, Earth};
EarthView.CoordinateSystem = EarthMJ2000Eq;
EarthView.DrawObject = [true true true true true true true true true true true true true true true true true true true true true true true];
EarthView.ViewScaleFactor = 3;
EarthView.ViewUpCoordinateSystem = EarthMJ2000Eq;
EarthView.ViewUpAxis = Z;
EarthView.SunLine = Off;

%-----------------------------------------------------------
% VISUALIZATION 2 - Earth-fixed view REMOVED (reduces load)
%-----------------------------------------------------------

%-----------------------------------------------------------
% VISUALIZATION 3 - Ground tracks all objects
%-----------------------------------------------------------

Create GroundTrackPlot GroundTrackAll;
GroundTrackAll.Add = {DEBRIX1, DEBRIX2, DEBRIX3, DEBRIX4, DEBRIX5, DEBRIX6, DEBRIX7, DEBRIX8, DEBRIX9, DEBRIX10, COLLECTOR, DebrisA, DebrisB, DebrisC, DebrisD, DebrisE, DebrisF, DebrisG, DebrisH, DebrisI, DebrisJ};
GroundTrackAll.CentralBody = Earth;
GroundTrackAll.DataCollectFrequency = 1;
GroundTrackAll.UpdatePlotFrequency = 50;
GroundTrackAll.NumPointsToRedraw = 0;
GroundTrackAll.ShowPlot = true;

%-----------------------------------------------------------
% VISUALIZATION 4 - Swarm formation closeup
%-----------------------------------------------------------

Create OrbitView SwarmFormation;
SwarmFormation.Add = {DEBRIX1, DEBRIX2, DEBRIX3, DEBRIX4, DEBRIX5, DEBRIX6, DEBRIX7, DEBRIX8, DEBRIX9, DEBRIX10, Earth};
SwarmFormation.CoordinateSystem = EarthMJ2000Eq;
SwarmFormation.DrawObject = [true true true true true true true true true true true];
SwarmFormation.ViewScaleFactor = 2;
SwarmFormation.ViewUpCoordinateSystem = EarthMJ2000Eq;
SwarmFormation.ViewUpAxis = Z;
SwarmFormation.SunLine = Off;

%-----------------------------------------------------------
% VISUALIZATION 5 - COLLECTOR full de-orbit to Earth
%-----------------------------------------------------------

Create OrbitView CollectorView;
CollectorView.Add = {COLLECTOR, Earth};
CollectorView.CoordinateSystem = EarthMJ2000Eq;
CollectorView.DrawObject = [true true];
CollectorView.ViewScaleFactor = 2;
CollectorView.ViewUpCoordinateSystem = EarthMJ2000Eq;
CollectorView.ViewUpAxis = Z;
CollectorView.SunLine = Off;

%-----------------------------------------------------------
% VISUALIZATION 6 - Debris cloud view REMOVED (reduces load)
%-----------------------------------------------------------

%-----------------------------------------------------------
% VISUALIZATION 7 - DeorbitView REMOVED (duplicate of CollectorView)
%-----------------------------------------------------------

%-----------------------------------------------------------
% VISUALIZATION 8 - SwarmDebrisTrack REMOVED (GroundTrackAll covers this)
%-----------------------------------------------------------

%-----------------------------------------------------------
% VISUALIZATIONS 9-15 REMOVED (reduced to prevent GMAT crash)
%-----------------------------------------------------------

%===========================================================
% MISSION SEQUENCE
%===========================================================

BeginMissionSequence;

%-----------------------------------------------------------
% PHASE 1 - BASELINE SNAPSHOT
%-----------------------------------------------------------

phase = 1;
Report SwarmLog debrisCount swarmSignal phase reentryFlag COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.TotalMass;
Report CollectorOrbitLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.RAAN COLLECTOR.AOP COLLECTOR.TA COLLECTOR.Altitude COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ COLLECTOR.TotalMass;
Report AltitudeLog DEBRIX1.UTCGregorian DEBRIX1.Altitude DEBRIX2.Altitude DEBRIX3.Altitude COLLECTOR.Altitude DebrisA.Altitude DebrisB.Altitude DebrisC.Altitude DebrisD.Altitude DebrisE.Altitude;
Report SwarmHealthLog DEBRIX1.UTCGregorian DEBRIX1.SMA DEBRIX2.SMA DEBRIX3.SMA DEBRIX4.SMA DEBRIX5.SMA DEBRIX6.SMA DEBRIX7.SMA DEBRIX8.SMA DEBRIX9.SMA DEBRIX10.SMA;
Report PeriApoLog DEBRIX1.UTCGregorian DEBRIX1.RadPer DEBRIX1.RadApo COLLECTOR.RadPer COLLECTOR.RadApo DebrisA.RadPer DebrisA.RadApo DebrisB.RadPer DebrisB.RadApo;
Report DeorbitEventLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo COLLECTOR.TotalMass dv_total debrisCount swarmSignal reentryFlag;
Report DeltaVLog COLLECTOR.UTCGregorian dv1 dv2 dv3 dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo;
Report EccentricityLog DEBRIX1.UTCGregorian DEBRIX1.ECC DEBRIX2.ECC DEBRIX3.ECC DEBRIX4.ECC DEBRIX5.ECC DEBRIX6.ECC DEBRIX7.ECC DEBRIX8.ECC DEBRIX9.ECC DEBRIX10.ECC COLLECTOR.ECC;
Report InclinationLog DEBRIX1.UTCGregorian DEBRIX1.INC DEBRIX2.INC DEBRIX3.INC DEBRIX4.INC DEBRIX5.INC DEBRIX6.INC DEBRIX7.INC DEBRIX8.INC DEBRIX9.INC DEBRIX10.INC COLLECTOR.INC;
Report SMAEvolutionLog DEBRIX1.UTCGregorian DEBRIX1.SMA DEBRIX2.SMA DEBRIX3.SMA DEBRIX4.SMA DEBRIX5.SMA DEBRIX6.SMA DEBRIX7.SMA DEBRIX8.SMA DEBRIX9.SMA DEBRIX10.SMA COLLECTOR.SMA DebrisA.SMA DebrisB.SMA DebrisC.SMA;
Report CartesianStateLog COLLECTOR.UTCGregorian COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ DEBRIX1.X DEBRIX1.Y DEBRIX1.Z DEBRIX1.VX DEBRIX1.VY DEBRIX1.VZ DebrisA.X DebrisA.Y DebrisA.Z;
Report MissionSummaryLog COLLECTOR.UTCGregorian phase debrisCount swarmSignal reentryFlag dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.Altitude COLLECTOR.ECC COLLECTOR.INC;

%-----------------------------------------------------------
% PHASE 2 - DEPLOYMENT PROPAGATION (Day 0 to Day 1)
%-----------------------------------------------------------

phase = 2;

Propagate OrbitProp(DEBRIX1, DEBRIX2, DEBRIX3, DEBRIX4, DEBRIX5, DEBRIX6, DEBRIX7, DEBRIX8, DEBRIX9, DEBRIX10, DebrisA, DebrisB, DebrisC, DebrisD, DebrisE, DebrisF, DebrisG, DebrisH, DebrisI, DebrisJ, COLLECTOR) {DEBRIX1.ElapsedDays = 0.5};

Report AltitudeLog DEBRIX1.UTCGregorian DEBRIX1.Altitude DEBRIX2.Altitude DEBRIX3.Altitude COLLECTOR.Altitude DebrisA.Altitude DebrisB.Altitude DebrisC.Altitude DebrisD.Altitude DebrisE.Altitude;
Report SwarmHealthLog DEBRIX1.UTCGregorian DEBRIX1.SMA DEBRIX2.SMA DEBRIX3.SMA DEBRIX4.SMA DEBRIX5.SMA DEBRIX6.SMA DEBRIX7.SMA DEBRIX8.SMA DEBRIX9.SMA DEBRIX10.SMA;
Report RAANDriftLog DEBRIX1.UTCGregorian DEBRIX1.RAAN DEBRIX2.RAAN DEBRIX3.RAAN COLLECTOR.RAAN DebrisA.RAAN DebrisB.RAAN DebrisC.RAAN DebrisD.RAAN;
Report EccentricityLog DEBRIX1.UTCGregorian DEBRIX1.ECC DEBRIX2.ECC DEBRIX3.ECC DEBRIX4.ECC DEBRIX5.ECC DEBRIX6.ECC DEBRIX7.ECC DEBRIX8.ECC DEBRIX9.ECC DEBRIX10.ECC COLLECTOR.ECC;
Report InclinationLog DEBRIX1.UTCGregorian DEBRIX1.INC DEBRIX2.INC DEBRIX3.INC DEBRIX4.INC DEBRIX5.INC DEBRIX6.INC DEBRIX7.INC DEBRIX8.INC DEBRIX9.INC DEBRIX10.INC COLLECTOR.INC;

Propagate OrbitProp(DEBRIX1, DEBRIX2, DEBRIX3, DEBRIX4, DEBRIX5, DEBRIX6, DEBRIX7, DEBRIX8, DEBRIX9, DEBRIX10, DebrisA, DebrisB, DebrisC, DebrisD, DebrisE, DebrisF, DebrisG, DebrisH, DebrisI, DebrisJ, COLLECTOR) {DEBRIX1.ElapsedDays = 0.5};

Report SwarmLog debrisCount swarmSignal phase reentryFlag COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.TotalMass;
Report CollectorOrbitLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.RAAN COLLECTOR.AOP COLLECTOR.TA COLLECTOR.Altitude COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ COLLECTOR.TotalMass;
Report AltitudeLog DEBRIX1.UTCGregorian DEBRIX1.Altitude DEBRIX2.Altitude DEBRIX3.Altitude COLLECTOR.Altitude DebrisA.Altitude DebrisB.Altitude DebrisC.Altitude DebrisD.Altitude DebrisE.Altitude;
Report SwarmHealthLog DEBRIX1.UTCGregorian DEBRIX1.SMA DEBRIX2.SMA DEBRIX3.SMA DEBRIX4.SMA DEBRIX5.SMA DEBRIX6.SMA DEBRIX7.SMA DEBRIX8.SMA DEBRIX9.SMA DEBRIX10.SMA;
Report DebrisTrackLog DebrisA.UTCGregorian DebrisA.SMA DebrisA.ECC DebrisA.INC DebrisB.SMA DebrisB.ECC DebrisC.SMA DebrisC.ECC DebrisD.SMA DebrisD.ECC DebrisE.SMA DebrisE.ECC DebrisF.SMA DebrisG.SMA DebrisH.SMA DebrisI.SMA DebrisJ.SMA;
Report PeriApoLog DEBRIX1.UTCGregorian DEBRIX1.RadPer DEBRIX1.RadApo COLLECTOR.RadPer COLLECTOR.RadApo DebrisA.RadPer DebrisA.RadApo DebrisB.RadPer DebrisB.RadApo;
Report SMAEvolutionLog DEBRIX1.UTCGregorian DEBRIX1.SMA DEBRIX2.SMA DEBRIX3.SMA DEBRIX4.SMA DEBRIX5.SMA DEBRIX6.SMA DEBRIX7.SMA DEBRIX8.SMA DEBRIX9.SMA DEBRIX10.SMA COLLECTOR.SMA DebrisA.SMA DebrisB.SMA DebrisC.SMA;
Report CartesianStateLog COLLECTOR.UTCGregorian COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ DEBRIX1.X DEBRIX1.Y DEBRIX1.Z DEBRIX1.VX DEBRIX1.VY DEBRIX1.VZ DebrisA.X DebrisA.Y DebrisA.Z;
Report MissionSummaryLog COLLECTOR.UTCGregorian phase debrisCount swarmSignal reentryFlag dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.Altitude COLLECTOR.ECC COLLECTOR.INC;

%-----------------------------------------------------------
% PHASE 3 - DEBRIS DETECTION SWEEPS
%-----------------------------------------------------------

phase = 3;

debrisCount = debrisCount + 8;
Report SwarmLog debrisCount swarmSignal phase reentryFlag COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.TotalMass;
Report DeorbitEventLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo COLLECTOR.TotalMass dv_total debrisCount swarmSignal reentryFlag;
Report MissionSummaryLog COLLECTOR.UTCGregorian phase debrisCount swarmSignal reentryFlag dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.Altitude COLLECTOR.ECC COLLECTOR.INC;

Propagate OrbitProp(DEBRIX1, DEBRIX2, DEBRIX3, DEBRIX4, DEBRIX5, DEBRIX6, DEBRIX7, DEBRIX8, DEBRIX9, DEBRIX10, DebrisA, DebrisB, DebrisC, DebrisD, DebrisE, DebrisF, DebrisG, DebrisH, DebrisI, DebrisJ, COLLECTOR) {DEBRIX1.ElapsedDays = 0.25};

Report AltitudeLog DEBRIX1.UTCGregorian DEBRIX1.Altitude DEBRIX2.Altitude DEBRIX3.Altitude COLLECTOR.Altitude DebrisA.Altitude DebrisB.Altitude DebrisC.Altitude DebrisD.Altitude DebrisE.Altitude;
Report RAANDriftLog DEBRIX1.UTCGregorian DEBRIX1.RAAN DEBRIX2.RAAN DEBRIX3.RAAN COLLECTOR.RAAN DebrisA.RAAN DebrisB.RAAN DebrisC.RAAN DebrisD.RAAN;
Report EccentricityLog DEBRIX1.UTCGregorian DEBRIX1.ECC DEBRIX2.ECC DEBRIX3.ECC DEBRIX4.ECC DEBRIX5.ECC DEBRIX6.ECC DEBRIX7.ECC DEBRIX8.ECC DEBRIX9.ECC DEBRIX10.ECC COLLECTOR.ECC;
Report InclinationLog DEBRIX1.UTCGregorian DEBRIX1.INC DEBRIX2.INC DEBRIX3.INC DEBRIX4.INC DEBRIX5.INC DEBRIX6.INC DEBRIX7.INC DEBRIX8.INC DEBRIX9.INC DEBRIX10.INC COLLECTOR.INC;

debrisCount = debrisCount + 4;
Report SwarmLog debrisCount swarmSignal phase reentryFlag COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.TotalMass;
Report DeorbitEventLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo COLLECTOR.TotalMass dv_total debrisCount swarmSignal reentryFlag;
Report MissionSummaryLog COLLECTOR.UTCGregorian phase debrisCount swarmSignal reentryFlag dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.Altitude COLLECTOR.ECC COLLECTOR.INC;

%-----------------------------------------------------------
% PHASE 4 - THRESHOLD CROSSED: FULL EARTH RE-ENTRY
% debrisCount = 12 > threshold = 10
% Three-burn sequence drives COLLECTOR to Earth surface
%
%   Burn1 at apoapsis:  -150 m/s -> perigee ~200 km
%   Burn2 at apoapsis:  -150 m/s -> perigee ~80 km
%   Burn3 at periapsis: -100 m/s -> perigee below surface
%   Propagate to Altitude = 0 -> Earth surface impact
%-----------------------------------------------------------

phase = 4;

If debrisCount > threshold

   swarmSignal = 1;
   reentryFlag = 1;

   collectorSMA_pre = COLLECTOR.SMA;
   collectorECC_pre = COLLECTOR.ECC;

   Report SwarmLog debrisCount swarmSignal phase reentryFlag COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.TotalMass;
   Report DeorbitEventLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo COLLECTOR.TotalMass dv_total debrisCount swarmSignal reentryFlag;
   Report MissionSummaryLog COLLECTOR.UTCGregorian phase debrisCount swarmSignal reentryFlag dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.Altitude COLLECTOR.ECC COLLECTOR.INC;

   % Step 4a - Propagate to apoapsis for Burn 1
   Propagate OrbitProp(COLLECTOR) {COLLECTOR.Apoapsis};

   Report CollectorOrbitLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.RAAN COLLECTOR.AOP COLLECTOR.TA COLLECTOR.Altitude COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ COLLECTOR.TotalMass;
   Report DeorbitEventLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo COLLECTOR.TotalMass dv_total debrisCount swarmSignal reentryFlag;
   Report AltitudeLog DEBRIX1.UTCGregorian DEBRIX1.Altitude DEBRIX2.Altitude DEBRIX3.Altitude COLLECTOR.Altitude DebrisA.Altitude DebrisB.Altitude DebrisC.Altitude DebrisD.Altitude DebrisE.Altitude;
   Report PeriApoLog DEBRIX1.UTCGregorian DEBRIX1.RadPer DEBRIX1.RadApo COLLECTOR.RadPer COLLECTOR.RadApo DebrisA.RadPer DebrisA.RadApo DebrisB.RadPer DebrisB.RadApo;
   Report DeltaVLog COLLECTOR.UTCGregorian dv1 dv2 dv3 dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo;

   % Step 4b - BURN 1: retrograde -150 m/s, lowers perigee to ~200 km
   Maneuver DeorbitBurn1(COLLECTOR);
   dv1 = 0.150;
   dv_total = dv_total + 0.150;

   Report CollectorOrbitLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.RAAN COLLECTOR.AOP COLLECTOR.TA COLLECTOR.Altitude COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ COLLECTOR.TotalMass;
   Report DeorbitEventLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo COLLECTOR.TotalMass dv_total debrisCount swarmSignal reentryFlag;
   Report PeriApoLog DEBRIX1.UTCGregorian DEBRIX1.RadPer DEBRIX1.RadApo COLLECTOR.RadPer COLLECTOR.RadApo DebrisA.RadPer DebrisA.RadApo DebrisB.RadPer DebrisB.RadApo;
   Report DeltaVLog COLLECTOR.UTCGregorian dv1 dv2 dv3 dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo;
   Report MissionSummaryLog COLLECTOR.UTCGregorian phase debrisCount swarmSignal reentryFlag dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.Altitude COLLECTOR.ECC COLLECTOR.INC;

   % Step 4c - Propagate apoapsis to periapsis (log descent arc)
   Propagate OrbitProp(COLLECTOR) {COLLECTOR.Periapsis};

   Report CollectorOrbitLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.RAAN COLLECTOR.AOP COLLECTOR.TA COLLECTOR.Altitude COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ COLLECTOR.TotalMass;
   Report DeorbitEventLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo COLLECTOR.TotalMass dv_total debrisCount swarmSignal reentryFlag;
   Report AltitudeLog DEBRIX1.UTCGregorian DEBRIX1.Altitude DEBRIX2.Altitude DEBRIX3.Altitude COLLECTOR.Altitude DebrisA.Altitude DebrisB.Altitude DebrisC.Altitude DebrisD.Altitude DebrisE.Altitude;
   Report CartesianStateLog COLLECTOR.UTCGregorian COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ DEBRIX1.X DEBRIX1.Y DEBRIX1.Z DEBRIX1.VX DEBRIX1.VY DEBRIX1.VZ DebrisA.X DebrisA.Y DebrisA.Z;

   % Step 4d - Propagate back to apoapsis for Burn 2
   Propagate OrbitProp(COLLECTOR) {COLLECTOR.Apoapsis};

   Report CollectorOrbitLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.RAAN COLLECTOR.AOP COLLECTOR.TA COLLECTOR.Altitude COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ COLLECTOR.TotalMass;
   Report DeorbitEventLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo COLLECTOR.TotalMass dv_total debrisCount swarmSignal reentryFlag;
   Report PeriApoLog DEBRIX1.UTCGregorian DEBRIX1.RadPer DEBRIX1.RadApo COLLECTOR.RadPer COLLECTOR.RadApo DebrisA.RadPer DebrisA.RadApo DebrisB.RadPer DebrisB.RadApo;

   % Step 4e - BURN 2: retrograde -150 m/s, lowers perigee to ~80 km
   Maneuver DeorbitBurn2(COLLECTOR);
   dv2 = 0.150;
   dv_total = dv_total + 0.150;

   Report CollectorOrbitLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.RAAN COLLECTOR.AOP COLLECTOR.TA COLLECTOR.Altitude COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ COLLECTOR.TotalMass;
   Report DeorbitEventLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo COLLECTOR.TotalMass dv_total debrisCount swarmSignal reentryFlag;
   Report PeriApoLog DEBRIX1.UTCGregorian DEBRIX1.RadPer DEBRIX1.RadApo COLLECTOR.RadPer COLLECTOR.RadApo DebrisA.RadPer DebrisA.RadApo DebrisB.RadPer DebrisB.RadApo;
   Report DeltaVLog COLLECTOR.UTCGregorian dv1 dv2 dv3 dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo;
   Report MissionSummaryLog COLLECTOR.UTCGregorian phase debrisCount swarmSignal reentryFlag dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.Altitude COLLECTOR.ECC COLLECTOR.INC;

   % Step 4f - Propagate to periapsis for final kill burn
   Propagate OrbitProp(COLLECTOR) {COLLECTOR.Periapsis};

   Report CollectorOrbitLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.RAAN COLLECTOR.AOP COLLECTOR.TA COLLECTOR.Altitude COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ COLLECTOR.TotalMass;
   Report DeorbitEventLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo COLLECTOR.TotalMass dv_total debrisCount swarmSignal reentryFlag;
   Report AltitudeLog DEBRIX1.UTCGregorian DEBRIX1.Altitude DEBRIX2.Altitude DEBRIX3.Altitude COLLECTOR.Altitude DebrisA.Altitude DebrisB.Altitude DebrisC.Altitude DebrisD.Altitude DebrisE.Altitude;
   Report CartesianStateLog COLLECTOR.UTCGregorian COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ DEBRIX1.X DEBRIX1.Y DEBRIX1.Z DEBRIX1.VX DEBRIX1.VY DEBRIX1.VZ DebrisA.X DebrisA.Y DebrisA.Z;

   % Step 4g - BURN 3: -100 m/s at periapsis drives perigee below Earth surface
   Maneuver DeorbitBurn3(COLLECTOR);
   dv3 = 0.100;
   dv_total = dv_total + 0.100;

   collectorSMA_post = COLLECTOR.SMA;
   collectorECC_post = COLLECTOR.ECC;

   Report CollectorOrbitLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.RAAN COLLECTOR.AOP COLLECTOR.TA COLLECTOR.Altitude COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ COLLECTOR.TotalMass;
   Report DeorbitEventLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo COLLECTOR.TotalMass dv_total debrisCount swarmSignal reentryFlag;
   Report PeriApoLog DEBRIX1.UTCGregorian DEBRIX1.RadPer DEBRIX1.RadApo COLLECTOR.RadPer COLLECTOR.RadApo DebrisA.RadPer DebrisA.RadApo DebrisB.RadPer DebrisB.RadApo;
   Report DeltaVLog COLLECTOR.UTCGregorian dv1 dv2 dv3 dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo;
   Report MissionSummaryLog COLLECTOR.UTCGregorian phase debrisCount swarmSignal reentryFlag dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.Altitude COLLECTOR.ECC COLLECTOR.INC;

   % Step 4h - Propagate COLLECTOR to Earth surface impact (Altitude = 0)
   Propagate OrbitProp(COLLECTOR) {COLLECTOR.Altitude = 0};

   % Final impact state log
   fuelRemaining = COLLECTOR.TotalMass;

   Report CollectorOrbitLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.RAAN COLLECTOR.AOP COLLECTOR.TA COLLECTOR.Altitude COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ COLLECTOR.TotalMass;
   Report DeorbitEventLog COLLECTOR.UTCGregorian COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo COLLECTOR.TotalMass dv_total debrisCount swarmSignal reentryFlag;
   Report SwarmLog debrisCount swarmSignal phase reentryFlag COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.INC COLLECTOR.TotalMass;
   Report AltitudeLog DEBRIX1.UTCGregorian DEBRIX1.Altitude DEBRIX2.Altitude DEBRIX3.Altitude COLLECTOR.Altitude DebrisA.Altitude DebrisB.Altitude DebrisC.Altitude DebrisD.Altitude DebrisE.Altitude;
   Report DeltaVLog COLLECTOR.UTCGregorian dv1 dv2 dv3 dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.ECC COLLECTOR.Altitude COLLECTOR.RadPer COLLECTOR.RadApo;
   Report CartesianStateLog COLLECTOR.UTCGregorian COLLECTOR.X COLLECTOR.Y COLLECTOR.Z COLLECTOR.VX COLLECTOR.VY COLLECTOR.VZ DEBRIX1.X DEBRIX1.Y DEBRIX1.Z DEBRIX1.VX DEBRIX1.VY DEBRIX1.VZ DebrisA.X DebrisA.Y DebrisA.Z;
   Report MissionSummaryLog COLLECTOR.UTCGregorian phase debrisCount swarmSignal reentryFlag dv_total COLLECTOR.TotalMass COLLECTOR.SMA COLLECTOR.Altitude COLLECTOR.ECC COLLECTOR.INC;

EndIf;

%-----------------------------------------------------------
% PHASE 5 - SWARM CONTINUES POST IMPACT
%-----------------------------------------------------------

phase = 5;

Propagate OrbitProp(DEBRIX1, DEBRIX2, DEBRIX3, DEBRIX4, DEBRIX5, DEBRIX6, DEBRIX7, DEBRIX8, DEBRIX9, DEBRIX10, DebrisA, DebrisB, DebrisC, DebrisD, DebrisE, DebrisF, DebrisG, DebrisH, DebrisI, DebrisJ) {DEBRIX1.ElapsedDays = 1};

