Create Variable dv3;
Create Variable phase;
Create Variable reentryFlag;
Create Variable missionElapsed;
Create Variable orbitPeriod;
Create Variable collectorSMA_pre;
Create Variable collectorSMA_post;
Create Variable collectorECC_pre;
Create Variable collectorECC_post;
Create Variable perigeeAlt;
Create Variable apogeeAlt;

debrisCount = 0;
threshold = 10;
swarmSignal = 0;
fuelRemaining = 80;
dv_total = 0;
dv1 = 0;
dv2 = 0;
dv3 = 0;
phase = 1;
reentryFlag = 0;
missionElapsed = 0;
orbitPeriod = 0;
collectorSMA_pre = 0;
collectorSMA_post = 0;
collectorECC_pre = 0;
collectorECC_post = 0;
perigeeAlt = 0;
apogeeAlt = 0;

%-----------------------------------------------------------
% REPORT FILES
%-----------------------------------------------------------

Create ReportFile SwarmLog;
SwarmLog.Filename = 'debrix_swarm_log.txt';
SwarmLog.Add = {DEBRIX1.UTCGregorian, debrisCount, swarmSignal, phase, reentryFlag, COLLECTOR.SMA, COLLECTOR.ECC, COLLECTOR.INC, COLLECTOR.TotalMass};
SwarmLog.WriteHeaders = true;
SwarmLog.ColumnWidth = 22;

Create ReportFile CollectorOrbitLog;
CollectorOrbitLog.Filename = 'collector_orbit_log.txt';
CollectorOrbitLog.Add = {COLLECTOR.UTCGregorian, COLLECTOR.SMA, COLLECTOR.ECC, COLLECTOR.INC, COLLECTOR.RAAN, COLLECTOR.AOP, COLLECTOR.TA, COLLECTOR.Altitude, COLLECTOR.X, COLLECTOR.Y, COLLECTOR.Z, COLLECTOR.VX, COLLECTOR.VY, COLLECTOR.VZ, COLLECTOR.TotalMass};
CollectorOrbitLog.WriteHeaders = true;
CollectorOrbitLog.ColumnWidth = 22;

