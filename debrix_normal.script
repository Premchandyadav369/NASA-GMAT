% Extended with 3 intermediate checkpoints at day 5, 10, 20, 30
%-----------------------------------------------------------

phase = 7;

Propagate OrbitProp(DEBRIX1, DEBRIX2, DEBRIX3, DEBRIX4, DEBRIX5, DEBRIX6, DEBRIX7, DEBRIX8, DEBRIX9, DEBRIX10, DebrisA, DebrisB, DebrisC, DebrisD, DebrisE, DebrisF, DebrisG, DebrisH, DebrisI, DebrisJ) {DEBRIX1.ElapsedDays = 5};

